    <limit lower="-1.745529" upper="0.001" effort="12" velocity="17.80"/>
    <dynamics damping="0.12" friction="0.05"/>
  </joint>

  <link name="RF_FOOT">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.022"/>
      </geometry>
      <material name="foot_blue">
        <color rgba="0.08 0.15 0.38 1"/>
