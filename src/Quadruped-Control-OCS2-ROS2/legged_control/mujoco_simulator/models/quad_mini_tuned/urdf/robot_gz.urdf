<?xml version="1.0" encoding="utf-8"?>
<robot name="quad_mini">

  <link name="base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="floating_base" type="fixed">
    <origin rpy="0 0 3.14159265359" xyz="0 0 0"/>
    <parent link="base"/>
    <child link="trunk"/>
  </joint>

  <!-- BASE LINK -->
  <link name="trunk">
    <inertial>
      <origin xyz="-0.0069912 0.01165 -0.0071119" rpy="0 0 0"/>
      <mass value="4.1"/>
      <inertia ixx="0.014" ixy="0.0" ixz="0.0" iyy="0.058" iyz="0.0" izz="0.063"/>
    </inertial>
    <visual>
      <origin xyz="0 0.01165 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.obj"/>
      </geometry>
      <material name="body_white">
        <color rgba="0.985 0.985 0.97 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0.01165 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.16 0.11"/>
      </geometry>
    </collision>
  </link>

  <!-- RIGHT FRONT LEG -->
  <link name="RF_hip">
    <inertial>
      <origin xyz="0.03 0.05 0.0" rpy="0 0 0"/>
      <mass value="0.39"/>
      <inertia ixx="2.4616E-05" ixy="-8.0494E-07" ixz="2.0469E-07" iyy="2.4611E-05" iyz="1.6554E-07" izz="2.5415E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/FR_HipX.obj"/>
      </geometry>
      <material name="body_white">
        <color rgba="0.985 0.985 0.97 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/FR_HipX.obj"/>
      </geometry>
    </collision>
  </link>

  <joint name="RF_HAA" type="revolute">
    <origin xyz="-0.15015 0.043877 0.009137" rpy="0 0 0"/>
    <parent link="trunk"/>
    <child link="RF_hip"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.436332" upper="0.436332" effort="12" velocity="11.52"/>
    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <link name="RF_thigh">
    <inertial>
      <origin xyz="0.0 0.040 -0.020" rpy="0 0 0"/>
      <mass value="0.725"/>
      <inertia ixx="4.7874E-05" ixy="-7.5529E-07" ixz="1.9319E-05" iyy="8.801E-05" iyz="-2.9232E-08" izz="7.0444E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/FR_HipY.obj"/>
      </geometry>
      <material name="body_white">
        <color rgba="0.985 0.985 0.97 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/FR_HipY.obj"/>
      </geometry>
    </collision>
  </link>

  <joint name="RF_HFE" type="revolute">
    <origin xyz="0.033575 0.0327 0" rpy="0 0 0"/>
    <parent link="RF_hip"/>
    <child link="RF_thigh"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.1745" upper="3.316" effort="12" velocity="17.80"/>
    <dynamics damping="0.10" friction="0.01"/>
  </joint>

  <link name="RF_calf">
    <inertial>
      <origin xyz="-0.020 0.0 0.0" rpy="0 0 0"/>
      <mass value="0.106"/>
      <inertia ixx="4.8323E-06" ixy="-9.407E-09" ixz="5.6754E-07" iyy="1.731E-05" iyz="1.0071E-09" izz="1.675E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/FR_Knee.obj"/>
      </geometry>
      <material name="knee_orange">
        <color rgba="0.97 0.50 0.08 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/FR_Knee.obj"/>
      </geometry>
    </collision>
