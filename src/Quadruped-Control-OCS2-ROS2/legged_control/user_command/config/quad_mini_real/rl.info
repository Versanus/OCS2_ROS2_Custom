; Quad mini real RL config for the exported ONNX joystick policy.
; Observation layout:
;   local linear velocity, gyro, projected gravity,
;   joint positions minus default angles, joint velocities, previous action, user command.
; Policy action and joint observation layout follow the training MuJoCo order:
;   RF, LF, RH, LH.
; Exported checkpoint:
;   Kp=30.0, Kd=1.0, actionScale=0.5, ctrl_dt=0.02.
; RL publishes gain ratios. In MuJoCo RL mode, ratio 1.0 maps to Kp=30.0, Kd=1.0.
; MuJoCo sim overrides below are used only when launching sim with controlType=rl.

onnxModelPath ../../models/quad_mini_rough_policy.onnx
onnxInputName obs
onnxOutputName continuous_actions

policyHz 50.0
mujocoTimestep 0.004
mujocoControlFrequency 50.0
mujocoBaseKp 30.0
mujocoBaseKd 1.0
mujocoDirectPositionControl true
obsDim 48
actDim 12
observationLayout training
jointPositionObservation relative_to_default
; MuJoCo feedback is already in policy joint coordinates.
; run.sh overrides this to quad_mini_hardware when backend=real.
feedbackJointStateTransform none
policyActionJointOrder
{
  [0]  RF_HAA
  [1]  RF_HFE
  [2]  RF_KFE
  [3]  LF_HAA
  [4]  LF_HFE
  [5]  LF_KFE
  [6]  RH_HAA
  [7]  RH_HFE
  [8]  RH_KFE
  [9]  LH_HAA
  [10] LH_HFE
  [11] LH_KFE
}
policyJointObservationOrder
{
  [0]  RF_HAA
  [1]  RF_HFE
  [2]  RF_KFE
  [3]  LF_HAA
  [4]  LF_HFE
  [5]  LF_KFE
  [6]  RH_HAA
  [7]  RH_HFE
  [8]  RH_KFE
  [9]  LH_HAA
  [10] LH_HFE
  [11] LH_KFE
}

; Internal controller order is LF, LH, RF, RH. Values match the training XML home keyframe.
; This is only the RL q_default used in q_des = q_default + actionScale * action.
policyDefaultJointState
{
   (0,0)   0.0   ; LF_HAA
   (1,0)  -0.3   ; LF_HFE
   (2,0)   1.2   ; LF_KFE
   (3,0)   0.0   ; LH_HAA
   (4,0)  -0.3   ; LH_HFE
   (5,0)   1.2   ; LH_KFE
   (6,0)   0.0   ; RF_HAA
   (7,0)   0.3   ; RF_HFE
   (8,0)  -1.2   ; RF_KFE
   (9,0)   0.0   ; RH_HAA
   (10,0)  0.3   ; RH_HFE
   (11,0) -1.2   ; RH_KFE
}

actionScale 0.5
actionClip 1.0
actionRateLimit 0.0

kpRatio 1.0
kdRatio 1.0

poseKpRatio 1.0
poseKdRatio 1.0

stateTimeoutSec 0.25
commandTimeoutSec 1.0
startupHoldSec 0.0
standTransitionSec 1.0
sitTransitionSec 1.0
policyCommandMaxX 1.5
policyCommandMaxY 0.5
policyCommandMaxYaw 1.5
; Policy command observation is real velocity units: [x_vel, y_vel, yaw_vel].
; Keep axis sign correction, but do not scale keyboard speed to the training limit.
scaleCommandToPolicyLimits false
