; Quad mini tuned RL config for the exported ONNX joystick policy.
; Keep this file focused on policy-specific settings and the RL startup/runtime contract.
; Defaults in code cover ONNX names, dims, observation layout, clips, timeouts, and debug settings.

onnxModelPath ../../models/quad_mini_rough_policy.onnx

stateEstimator
{
  enabled false
  type inekf
  orientationSource ekf
}

mujocoTimestep 0.001
mujocoControlFrequency 50.0
mujocoBaseKp 20.0
mujocoBaseKd 0.5
mujocoJointDamping 1.0
mujocoUseXmlJointDynamics true
mujocoDirectPositionControl false

; Policy joint order in MuJoCo training convention: RF, LF, RH, LH.
policyActionJointOrder
{
  [0]  RF_HAA
  [1]  RF_HFE
  [2]  RF_KFE
  [3]  LF_HAA
  [4]  LF_HFE
  [5]  LF_KFE
  [6]  RH_HAA
  [7]  RH_HFE
  [8]  RH_KFE
  [9]  LH_HAA
  [10] LH_HFE
  [11] LH_KFE
}

; Internal controller order is LF, LH, RF, RH.
; This is only the RL q_default used in observation/action space.
policyDefaultJointState
{
   (0,0)   0.0   ; LF_HAA
   (1,0)  -0.3   ; LF_HFE
   (2,0)   1.2   ; LF_KFE
   (3,0)   0.0   ; LH_HAA
   (4,0)  -0.3   ; LH_HFE
   (5,0)   1.2   ; LH_KFE
   (6,0)   0.0   ; RF_HAA
   (7,0)   0.3   ; RF_HFE
   (8,0)  -1.2   ; RF_KFE
   (9,0)   0.0   ; RH_HAA
   (10,0)  0.3   ; RH_HFE
   (11,0) -1.2   ; RH_KFE
}

; RL operator stand hold pose.
rlStandJointState
{
   (0,0)  -0.00   ; LF_HAA
   (1,0)  -0.70   ; LF_HFE
   (2,0)   1.20   ; LF_KFE
   (3,0)   0.00   ; LH_HAA
   (4,0)  -0.30   ; LH_HFE
   (5,0)   1.20   ; LH_KFE
   (6,0)   0.00   ; RF_HAA
   (7,0)   0.70   ; RF_HFE
   (8,0)  -1.20   ; RF_KFE
   (9,0)  -0.00   ; RH_HAA
   (10,0)  0.30   ; RH_HFE
   (11,0) -1.20   ; RH_KFE
}

; RL operator sit pose.
rlSitJointState
{
   (0,0)   0.0   ; LF_HAA
   (1,0)   0.0   ; LF_HFE
   (2,0)   0.20  ; LF_KFE
   (3,0)   0.0   ; LH_HAA
   (4,0)   0.0   ; LH_HFE
   (5,0)   0.20  ; LH_KFE
   (6,0)   0.0   ; RF_HAA
   (7,0)   0.0   ; RF_HFE
   (8,0)  -0.20  ; RF_KFE
   (9,0)   0.0   ; RH_HAA
   (10,0)  0.0   ; RH_HFE
   (11,0) -0.20  ; RH_KFE
}

; RL operator recovery pose.
rlRecoveryJointState
{
   (0,0)  -0.00   ; LF_HAA
   (1,0)  -0.70   ; LF_HFE
   (2,0)   1.30   ; LF_KFE
   (3,0)   0.00   ; LH_HAA
   (4,0)  -0.30   ; LH_HFE
   (5,0)   1.20   ; LH_KFE
   (6,0)   0.00   ; RF_HAA
   (7,0)   0.70   ; RF_HFE
   (8,0)  -1.30   ; RF_KFE
   (9,0)  -0.00   ; RH_HAA
   (10,0)  0.30   ; RH_HFE
   (11,0) -1.20   ; RH_KFE
}

poseKpRatio 1.5
poseKdRatio 1.0

startupHoldSec 0.0
standTransitionSec 1.0
velocityCommandCap 2.0
requireCommandForPolicy false
holdStandWhenPolicyIdle false


actionClip 1.5
invertVelocityCommandXY false
