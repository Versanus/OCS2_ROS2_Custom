; Shared command limits.
; Used by user_command teleop and also by the RL backend to derive command remapping.
targetDisplacementVelocityForward   0.30;
targetDisplacementVelocityLateral   0.10;
targetRotationVelocity              0.5;

; Primarily MPC / whole-body-control side.
comHeight                           0.22

; Teleop / keyboard / gamepad settings.
; Not used directly by ONNX inference, but still used by user_command tooling.
teleop
{
  velocity_accel_limit_vx                1.50
  velocity_accel_limit_vy                1.00
  velocity_accel_limit_yaw               1.00
  velocity_preview_distance_low_speed   2.0
  velocity_preview_distance_high_speed  3.0
  velocity_preview_speed_low            1.0
  velocity_preview_speed_high           2.0

  gamepad
  {
    enabled                              true
    device                               /dev/input/js0
    axisDeadzone                         0.20
    digitalPressThreshold                0.60
    axisLateral                          3
    axisForward                          1
    axisYaw                              0
    dpadHorizontalAxis                   6
    dpadVerticalAxis                     7
    leftTriggerAxis                      2
    rightTriggerAxis                     5
    buttonA                              0
    buttonB                              1
    buttonX                              2
    buttonY                              3
    buttonLb                             4
    buttonRb                             5
  }
}

; Shared between RL and MPC paths.
; RL uses this for command sign / axis remap.
